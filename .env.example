# TweetViralitySimulator runs fully WITHOUT any keys (heuristic provider).
# Set one of these only if you want LLM-scored tweet DNA.

# OpenAI (provider=openai)
# OPENAI_API_KEY=sk-...
# TVS_OPENAI_MODEL=gpt-4o-mini

# Ollama / local models (provider=ollama) — no key needed, just a running daemon
# TVS_OLLAMA_HOST=http://localhost:11434
# TVS_OLLAMA_MODEL=llama3.1
